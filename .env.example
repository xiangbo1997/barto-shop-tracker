# 复制本文件为 .env 并填入真实值；切勿提交 .env 到版本控制

# ─────────────────────────────
# PostgreSQL（docker-compose 默认值，本地开发可直接用）
# ─────────────────────────────
DATABASE_URL=postgresql://barto:barto_dev@localhost:5432/barto

# ─────────────────────────────
# 服务端口
# ─────────────────────────────
API_PORT=3001
WEB_PORT=3000

# ─────────────────────────────
# LLM 中转站（OpenAI 兼容协议）
# 严格保密：填入实际 key 后，确认 .env 已被 .gitignore 忽略
# ─────────────────────────────
LLM_BASE_URL=https://your-relay-host/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o-mini
LLM_VISION_MODEL=gpt-4o-mini

# ─────────────────────────────
# 抓取行为（覆盖默认）
# ─────────────────────────────
SCRAPER_DEFAULT_TIER=1                # 0=静态优先 1=Playwright 默认 2=直接 LLM
SCRAPER_CONCURRENCY=5                 # 同时刷新的 URL 数
SCRAPER_BROWSER_POOL_SIZE=2           # 常驻 Chromium 实例数
SCRAPER_TIMEOUT_MS=30000

# ─────────────────────────────
# 定时刷新（pg-boss schedule）
# ─────────────────────────────
SCHEDULE_REFRESH_CRON=0 3 * * *       # cron 表达式（UTC），默认每天 03:00
SCHEDULE_REFRESH_BATCH=100            # 每轮最多刷新多少个最陈旧商品
FEATURE_SCHEDULED_REFRESH=true        # 关闭后不注册定时任务，仅手动刷新

# ─────────────────────────────
# 功能开关
# ─────────────────────────────
FEATURE_LLM_ENABLED=true              # 关闭后所有 LLM 调用直接失败
FEATURE_SMART_TOKEN_REFRESH=true      # D3：智能刷新 token

# ─────────────────────────────
# Tier 2 兜底：自建反爬抓取平台（过 Cloudflare + SPA 渲染）
# 本地 Tier 0/1 失败时调用，返回 HTML 复用本地解析器
# ─────────────────────────────
SCRAPE_API_URL=https://scrape.cloudsentryai.com
SCRAPE_API_KEY=                       # 留空则 Tier 2 跳过；服务器 .env 填真实 key
SCRAPE_TIMEOUT_MS=120000              # 过盾+渲染较慢，建议 >=120s
FEATURE_TIER2_SCRAPE=true             # 关闭后不调用平台

# ─────────────────────────────
# 应用内登录鉴权（web 层，替代 Caddy basic_auth）
# ─────────────────────────────
APP_AUTH_USER=barto                   # 登录用户名
APP_AUTH_PASSWORD=                    # 登录密码（服务器 .env 填强密码）
APP_AUTH_SECRET=                      # session 签名密钥（≥16 字符随机串）
